# Copy this file to ".env" and fill in your real key.
# ".env" is gitignored and must NEVER be committed. This template is safe to commit.

# Get one from https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=your-key-here

# Free weather API key from https://openweathermap.org/api -> API keys
# (new keys can take up to ~1 hour to activate)
OPENWEATHER_API_KEY=your-openweather-key-here

# Free attractions API key from https://opentripmap.io/product
OPENTRIPMAP_API_KEY=your-opentripmap-key-here
